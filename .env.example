
APP_NAME= TrimTrack
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL = https://trimtrack-ql05.onrender.com

NGROK_URL=

DEBUG=true

DATABASE_URL=postgresql+asyncpg://urlshortener:urlshortener@localhost:5432/urlshortener
SQLITE_FALLBACK=false
SQLITE_URL=sqlite+aiosqlite:///./urlshortener.db

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

MACHINE_ID=1

RATE_LIMIT_REDIRECT=100
RATE_LIMIT_CREATE=10
RATE_LIMIT_WINDOW=60

CACHE_TTL=86400
CACHE_WARM_TOP_N=1000

BLOOM_FILTER_CAPACITY=1000000
BLOOM_FILTER_ERROR_RATE=0.001

SAFETY_SCORE_THRESHOLD=0.5
ML_MODEL_PATH=ml/model.pkl

GEO_API_URL=http://ip-api.com/json

PROMETHEUS_ENABLED=true
